# GitHub App ID. Found on the GitHub App settings page.
APP_ID=

# GitHub App private key. Keep newline characters escaped when stored on one line.
PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"

# Webhook secret configured for the GitHub App.
WEBHOOK_SECRET=

# Optional Smee webhook proxy URL for local development.
WEBHOOK_PROXY_URL=

# Probot log level, for example trace, debug, info, warn, error, or fatal.
LOG_LEVEL=info

# AI provider. Supported values: deepseek, openai.
AI_PROVIDER=deepseek

# API key for the selected AI provider.
AI_API_KEY=

# Model used to review PR diffs.
AI_MODEL=deepseek-v4-pro

# Reasoning effort for review quality and latency tradeoff.
REASONING_EFFORT=high

# OpenAI-compatible API base URL. DeepSeek default: https://api.deepseek.com
AI_BASE_URL=https://api.deepseek.com

# Maximum response tokens allowed for a single model review.
AI_MAX_OUTPUT_TOKENS=8000

# Timeout in milliseconds for one model API attempt.
AI_REQUEST_TIMEOUT_MS=120000

# Maximum retry attempts for retryable model API failures.
AI_MAX_RETRIES=2

# Run reviews automatically on pull_request opened, reopened, and synchronize events.
AUTO_REVIEW_PR_EVENTS=true

# Review draft pull requests when automatic reviews are enabled.
REVIEW_DRAFTS=false

# Skip automatic review when this exact PR head SHA was already reviewed by the bot.
SKIP_DUPLICATE_REVIEWS=true

# Post a PR review when automatic model review fails. Manual /review failures are always posted.
POST_FAILURE_REVIEWS=false

# Allow GitHub suggestion blocks in inline comments after validation.
ENABLE_REVIEW_SUGGESTIONS=false

# Maximum number of changed files sent to the model.
REVIEW_MAX_FILES=30

# Maximum total patch characters sent to the model.
REVIEW_MAX_PATCH_CHARS=120000

# Maximum number of inline comments posted in one review.
REVIEW_MAX_INLINE_COMMENTS=30
